# EventoX Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/eventox

# Server port (default: 3000)
PORT=3000

# Public URL of the app (used for CORS whitelist)
# APP_URL=https://eventox-production.up.railway.app
